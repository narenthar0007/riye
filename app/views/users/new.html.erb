<div class="container-fluid">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">
            <i class="fas fa-user-plus"></i>
            Create New User
          </h3>
          <div class="card-tools">
            <%= link_to 'All Users', users_path, class: 'btn btn-secondary btn-sm' %>
          </div>
        </div>
        
        <%= form_with model: @user, local: true, class: 'needs-validation', novalidate: true do |form| %>
          <div class="card-body">
            <!-- Display errors if any -->
            <% if @user.errors.any? %>
              <div class="alert alert-danger">
                <h5><i class="fas fa-exclamation-triangle"></i> Please fix the following errors:</h5>
                <ul class="mb-0">
                  <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <!-- Super Admin Notice -->
            <% if current_user.super_admin? %>
              <div class="alert alert-info">
                <h6><i class="fas fa-star"></i> Super Admin Privileges</h6>
                <p class="mb-0">
                  You have super admin privileges and can create Administrator accounts.
                  This is because your email contains 'bluvent@gmail.com'.
                </p>
              </div>
            <% end %>

            <div class="row">
              <!-- Email Field -->
              <div class="col-md-12 mb-4">
                <label for="user_email" class="form-label">
                  <i class="fas fa-envelope text-muted"></i>
                  Email Address <span class="text-danger">*</span>
                </label>
                <%= form.email_field :email, class: 'form-control', placeholder: 'Enter user email address', 
                    required: true, id: 'user_email' %>
                <div class="invalid-feedback">
                  Please provide a valid email address.
                </div>
                <small class="text-muted">
                  The user will receive an email with login instructions.
                </small>
              </div>

              <!-- Password Fields -->
              <div class="col-md-6 mb-4">
                <label for="user_password" class="form-label">
                  <i class="fas fa-lock text-muted"></i>
                  Password <span class="text-danger">*</span>
                </label>
                <%= form.password_field :password, class: 'form-control', placeholder: 'Enter password', 
                    required: true, minlength: 6, id: 'user_password' %>
                <div class="invalid-feedback">
                  Password must be at least 6 characters long.
                </div>
              </div>

              <div class="col-md-6 mb-4">
                <label for="user_password_confirmation" class="form-label">
                  <i class="fas fa-lock text-muted"></i>
                  Confirm Password <span class="text-danger">*</span>
                </label>
                <%= form.password_field :password_confirmation, class: 'form-control', placeholder: 'Confirm password', 
                    required: true, minlength: 6, id: 'user_password_confirmation' %>
                <div class="invalid-feedback">
                  Password confirmation must match the password.
                </div>
              </div>

              <!-- Role Selection -->
              <div class="col-md-12 mb-4">
                <label for="user_role" class="form-label">
                  <i class="fas fa-user-tag text-muted"></i>
                  User Role <span class="text-danger">*</span>
                </label>
                <%= form.select :role, 
                    options_for_select(@available_roles), 
                    { prompt: 'Select a role...' }, 
                    { class: 'form-select', required: true, id: 'user_role' } %>
                <div class="invalid-feedback">
                  Please select a valid role.
                </div>
                
                <!-- Role descriptions -->
                <div id="role-descriptions" class="mt-3">
                  <div id="employee-desc" class="role-description alert alert-light" style="display: none;">
                    <strong><i class="fas fa-user text-secondary"></i> Employee:</strong>
                    Basic system access, can manage their own tasks and view assigned projects.
                    This is the default role for most users.
                  </div>
                  <div id="manager-desc" class="role-description alert alert-info" style="display: none;">
                    <strong><i class="fas fa-user-tie text-info"></i> Manager:</strong>
                    Can manage teams, oversee projects, supervise workers, and approve attendances.
                    Has elevated permissions for team management.
                  </div>
                  <% if current_user.super_admin? %>
                    <div id="admin-desc" class="role-description alert alert-danger" style="display: none;">
                      <strong><i class="fas fa-user-shield text-danger"></i> Administrator:</strong>
                      Full system access including user management, role assignments, and system configuration.
                      <span class="text-warning">
                        <i class="fas fa-exclamation-triangle"></i>
                        Can only be created by Super Admins (users with 'bluvent@gmail.com' in email).
                      </span>
                    </div>
                  <% end %>
                  <% if current_user.owner? %>
                    <div id="owner-desc" class="role-description alert alert-warning" style="display: none;">
                      <strong><i class="fas fa-crown text-warning"></i> Owner:</strong>
                      Complete system control with access to all features, financial data, and strategic decisions.
                      <span class="text-danger">
                        <i class="fas fa-exclamation-triangle"></i>
                        This role has maximum privileges. Use with caution.
                      </span>
                    </div>
                  <% end %>
                </div>

                <!-- Permission Notice -->
                <div class="mt-3">
                  <% unless current_user.super_admin? %>
                    <div class="alert alert-warning">
                      <h6><i class="fas fa-info-circle"></i> Role Limitations</h6>
                      <p class="mb-0">
                        You cannot create Administrator accounts because your email doesn't contain 'bluvent@gmail.com'.
                        Only Super Admins can create Administrator roles.
                      </p>
                    </div>
                  <% end %>
                  
                  <% unless current_user.owner? %>
                    <div class="alert alert-info">
                      <h6><i class="fas fa-info-circle"></i> Owner Role</h6>
                      <p class="mb-0">
                        Owner role is not available for creation. Only existing Owners can create new Owner accounts.
                      </p>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <div class="card-footer">
            <div class="d-flex justify-content-between">
              <%= link_to 'Cancel', users_path, class: 'btn btn-secondary' %>
              <%= form.submit 'Create User', class: 'btn btn-success', id: 'createUserBtn' %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Show role descriptions based on selection
    const roleSelect = document.getElementById('user_role');
    const descriptions = document.querySelectorAll('.role-description');
    
    function showRoleDescription() {
      // Hide all descriptions
      descriptions.forEach(desc => desc.style.display = 'none');
      
      // Show selected role description
      const selectedRole = roleSelect.value;
      if (selectedRole) {
        const descElement = document.getElementById(selectedRole + '-desc');
        if (descElement) {
          descElement.style.display = 'block';
        }
      }
    }
    
    // Show description for current selection
    showRoleDescription();
    
    // Show description when selection changes
    roleSelect.addEventListener('change', showRoleDescription);
    
    // Password confirmation validation
    const password = document.getElementById('user_password');
    const passwordConfirmation = document.getElementById('user_password_confirmation');
    const createBtn = document.getElementById('createUserBtn');
    
    function validatePasswordMatch() {
      if (password.value !== passwordConfirmation.value) {
        passwordConfirmation.setCustomValidity('Passwords do not match');
        createBtn.disabled = true;
      } else {
        passwordConfirmation.setCustomValidity('');
        createBtn.disabled = false;
      }
    }
    
    password.addEventListener('input', validatePasswordMatch);
    passwordConfirmation.addEventListener('input', validatePasswordMatch);
  });

  // Form validation
  (function() {
    'use strict';
    window.addEventListener('load', function() {
      var forms = document.getElementsByClassName('needs-validation');
      var validation = Array.prototype.filter.call(forms, function(form) {
        form.addEventListener('submit', function(event) {
          if (form.checkValidity() === false) {
            event.preventDefault();
            event.stopPropagation();
          }
          form.classList.add('was-validated');
        }, false);
      });
    }, false);
  })();
</script>
