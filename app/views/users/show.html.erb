<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">
            <i class="fas fa-user-circle"></i>
            User Details
          </h3>
          <div class="card-tools">
            <% if current_user.can_edit_user?(@user) %>
              <%= link_to 'Edit User', edit_user_path(@user), class: 'btn btn-warning btn-sm' %>
            <% end %>
            
            <% if current_user.can_delete_user?(@user) %>
              <%= link_to 'Delete User', user_path(@user), method: :delete, 
                  class: 'btn btn-danger btn-sm', 
                  confirm: "Are you sure you want to delete user '#{@user.email}'?" %>
            <% end %>
            
            <%= link_to 'All Users', users_path, class: 'btn btn-secondary btn-sm' %>
          </div>
        </div>
        <div class="card-body">
          <div class="row">
            <!-- User Information -->
            <div class="col-md-8">
              <h5>
                <i class="fas fa-id-card"></i>
                User Information
              </h5>
              <table class="table table-bordered">
                <tr>
                  <th width="30%">User ID</th>
                  <td><code>#<%= @user.id %></code></td>
                </tr>
                <tr>
                  <th>Email Address</th>
                  <td>
                    <i class="fas fa-envelope text-muted"></i>
                    <%= @user.email %>
                  </td>
                </tr>
                <tr>
                  <th>Role</th>
                  <td>
                    <% case @user.role %>
                    <% when 'admin' %>
                      <span class="badge bg-danger fs-6">
                        <i class="fas fa-user-shield"></i> 
                        Administrator
                        <% if @user.super_admin? %>
                          <i class="fas fa-star" title="Super Admin"></i>
                        <% end %>
                      </span>
                    <% when 'manager' %>
                      <span class="badge bg-info fs-6"><i class="fas fa-user-tie"></i> Manager</span>
                    <% when 'owner' %>
                      <span class="badge bg-warning fs-6"><i class="fas fa-crown"></i> Owner</span>
                    <% else %>
                      <span class="badge bg-secondary fs-6"><i class="fas fa-user"></i> Employee</span>
                    <% end %>
                    
                    <% if @user.super_admin? && @user.role != 'admin' %>
                      <br><small class="text-info">
                        <i class="fas fa-star"></i> 
                        Super Admin (can create administrators)
                      </small>
                    <% end %>
                  </td>
                </tr>
                <tr>
                  <th>Account Created</th>
                  <td>
                    <i class="fas fa-calendar text-muted"></i>
                    <%= @user.created_at.strftime("%B %d, %Y at %I:%M %p") %>
                  </td>
                </tr>
                <tr>
                  <th>Last Updated</th>
                  <td>
                    <i class="fas fa-clock text-muted"></i>
                    <%= @user.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
                  </td>
                </tr>
              </table>
            </div>

            <!-- Role Permissions Info -->
            <div class="col-md-4">
              <h5>
                <i class="fas fa-shield-alt"></i>
                Role Permissions
              </h5>
              <div class="card">
                <div class="card-body">
                  <% case @user.role %>
                  <% when 'admin' %>
                    <div class="text-center mb-3">
                      <i class="fas fa-user-shield fa-3x text-danger"></i>
                      <h6 class="mt-2 text-danger">Administrator</h6>
                    </div>
                    <ul class="list-unstyled">
                      <li><i class="fas fa-check text-success"></i> Full system access</li>
                      <li><i class="fas fa-check text-success"></i> User management</li>
                      <li><i class="fas fa-check text-success"></i> Role assignment</li>
                      <li><i class="fas fa-check text-success"></i> System configuration</li>
                    </ul>
                  <% when 'manager' %>
                    <div class="text-center mb-3">
                      <i class="fas fa-user-tie fa-3x text-info"></i>
                      <h6 class="mt-2 text-info">Manager</h6>
                    </div>
                    <ul class="list-unstyled">
                      <li><i class="fas fa-check text-success"></i> Team management</li>
                      <li><i class="fas fa-check text-success"></i> Project oversight</li>
                      <li><i class="fas fa-check text-success"></i> Worker supervision</li>
                      <li><i class="fas fa-times text-muted"></i> System configuration</li>
                    </ul>
                  <% when 'owner' %>
                    <div class="text-center mb-3">
                      <i class="fas fa-crown fa-3x text-warning"></i>
                      <h6 class="mt-2 text-warning">Owner</h6>
                    </div>
                    <ul class="list-unstyled">
                      <li><i class="fas fa-check text-success"></i> Full system access</li>
                      <li><i class="fas fa-check text-success"></i> Financial oversight</li>
                      <li><i class="fas fa-check text-success"></i> Strategic decisions</li>
                      <li><i class="fas fa-check text-success"></i> User management</li>
                    </ul>
                  <% else %>
                    <div class="text-center mb-3">
                      <i class="fas fa-user fa-3x text-secondary"></i>
                      <h6 class="mt-2 text-secondary">Employee</h6>
                    </div>
                    <ul class="list-unstyled">
                      <li><i class="fas fa-check text-success"></i> Basic system access</li>
                      <li><i class="fas fa-check text-success"></i> Task management</li>
                      <li><i class="fas fa-times text-muted"></i> User management</li>
                      <li><i class="fas fa-times text-muted"></i> System configuration</li>
                    </ul>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
