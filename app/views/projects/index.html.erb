<div class="animate-fade-in">

  <!-- Stats Cards -->
  <div class="stats-grid mb-5">
    <div class="stat-card">
      <div class="stat-icon text-primary">
        <i class="fas fa-project-diagram"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @projects.count %></h3>
        <p class="stat-label">Total Projects</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-success">
        <i class="fas fa-check-circle"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @active_projects.count %></h3>
        <p class="stat-label">Active Projects</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-danger">
        <i class="fas fa-exclamation-triangle"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @overdue_projects.count %></h3>
        <p class="stat-label">Overdue Projects</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-info">
        <i class="fas fa-calendar-plus"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @upcoming_projects.count %></h3>
        <p class="stat-label">Upcoming Projects</p>
      </div>
    </div>
  </div>

  <!-- Projects Table -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">
        <i class="fas fa-list"></i>
        All Projects
      </h3>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-hover table-striped mb-0">
          <thead class="table-dark">
            <tr>
              <th><i class="fas fa-project-diagram"></i> Project Name</th>
              <th><i class="fas fa-map-marker-alt"></i> Location</th>
              <th><i class="fas fa-building"></i> Company</th>
              <th><i class="fas fa-calendar-alt"></i> Start Date</th>
              <th><i class="fas fa-calendar-check"></i> End Date</th>
              <th><i class="fas fa-dollar-sign"></i> Budget</th>
              <th><i class="fas fa-info-circle"></i> Status</th>
              <th class="text-end"><i class="fas fa-cogs"></i> Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if @projects.any? %>
              <% @projects.each do |project| %>
                <tr class="<%= 'table-danger' if project.overdue? %>">
                  <td>
                    <div class="d-flex align-items-center">
                      <i class="fas fa-project-diagram text-primary me-2"></i>
                      <div>
                        <strong><%= project.name %></strong>
                        <% if project.overdue? %>
                          <br><small class="text-danger">
                            <i class="fas fa-exclamation-triangle"></i>
                            OVERDUE
                          </small>
                        <% end %>
                      </div>
                    </div>
                  </td>
                  <td>
                    <i class="fas fa-map-marker-alt text-info me-1"></i>
                    <%= project.location || 'Not specified' %>
                  </td>
                  <td>
                    <% if project.company %>
                      <i class="fas fa-building text-warning me-1"></i>
                      <%= project.company.name %>
                    <% else %>
                      <span class="text-muted">No company assigned</span>
                    <% end %>
                  </td>
                  <td>
                    <i class="fas fa-calendar-alt text-success me-1"></i>
                    <%= project.start_date&.strftime("%b %d, %Y") || 'Not set' %>
                  </td>
                  <td>
                    <i class="fas fa-calendar-check text-<%= project.overdue? ? 'danger' : 'info' %> me-1"></i>
                    <%= project.end_date&.strftime("%b %d, %Y") || 'Not set' %>
                    <% if project.overdue? %>
                      <br><small class="text-danger">
                        <i class="fas fa-clock"></i>
                        <%= pluralize(project.days_remaining.abs, 'day') %> overdue
                      </small>
                    <% elsif project.active? %>
                      <br><small class="text-success">
                        <i class="fas fa-clock"></i>
                        <%= pluralize(project.days_remaining, 'day') %> remaining
                      </small>
                    <% end %>
                  </td>
                  <td>
                    <i class="fas fa-dollar-sign text-success me-1"></i>
                    <%= number_to_currency(project.customer_budget || 0) %>
                  </td>
                  <td>
                    <span class="badge bg-<%= project.status_color %>">
                      <% case project.status %>
                      <% when 'overdue' %>
                        <i class="fas fa-exclamation-triangle"></i> Overdue
                      <% when 'active' %>
                        <i class="fas fa-check-circle"></i> Active
                      <% when 'upcoming' %>
                        <i class="fas fa-calendar-plus"></i> Upcoming
                      <% else %>
                        <i class="fas fa-question-circle"></i> <%= project.status&.titleize || 'Unknown' %>
                      <% end %>
                    </span>
                  </td>
                  <td class="text-end">
                    <div class="btn-group btn-group-sm">
                      <%= link_to project_path(project), class: 'btn btn-outline-primary', title: 'View Details' do %>
                        <i class="fas fa-eye"></i>
                      <% end %>
                      <%= link_to edit_project_path(project), class: 'btn btn-outline-warning', title: 'Edit Project' do %>
                        <i class="fas fa-edit"></i>
                      <% end %>
                      <%= link_to project_path(project), method: :delete, 
                          class: 'btn btn-outline-danger', title: 'Delete Project',
                          confirm: 'Are you sure you want to delete this project?' do %>
                        <i class="fas fa-trash"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="8" class="text-center text-muted py-4">
                  <i class="fas fa-project-diagram fa-2x mb-2"></i>
                  <br>No projects found. <br>
                  <%= link_to 'Create your first project', new_project_path, class: 'btn btn-success btn-sm mt-2' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>