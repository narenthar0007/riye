<%= form_with(model: project, local: true, class: 'modern-form') do |form| %>
  <% if project.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <div class="d-flex align-center gap-2 mb-3">
        <i class="fas fa-exclamation-triangle fa-lg"></i>
        <h3 class="mb-0">Please fix the following errors:</h3>
      </div>
      <ul class="mb-0">
        <% project.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <!-- Project Information Section -->
    <div class="col-md-6 mb-4">
      <div class="form-section">
        <h3 class="form-section-title">
          <i class="fas fa-project-diagram"></i>
          Project Details
        </h3>
        
        <div class="form-group">
          <%= form.label :name, class: 'form-label required' do %>
            <i class="fas fa-building"></i>
            Project Name
          <% end %>
          <%= form.text_field :name, class: 'form-control', 
              placeholder: 'Enter project name',
              required: true %>
          <small class="form-text">Descriptive name for the construction project</small>
        </div>

        <div class="form-group">
          <%= form.label :location, class: 'form-label required' do %>
            <i class="fas fa-map-marker-alt"></i>
            Location
          <% end %>
          <%= form.text_field :location, class: 'form-control', 
              placeholder: 'Enter project location',
              required: true %>
          <small class="form-text">Physical location where the project will be executed</small>
        </div>

        <div class="form-group">
          <%= form.label :status, class: 'form-label required' do %>
            <i class="fas fa-flag"></i>
            Project Status
          <% end %>
          <%= form.select :status, 
              options_for_select([
                ['Planning', 'Planning'],
                ['Active', 'Active'], 
                ['On Hold', 'On Hold'],
                ['Completed', 'Completed'],
                ['Cancelled', 'Cancelled']
              ], project.status), 
              { prompt: 'Select project status' }, 
              { class: 'form-control', required: true } %>
          <small class="form-text">Current status of the project</small>
        </div>

        <div class="form-group">
          <%= form.label :start_date, class: 'form-label required' do %>
            <i class="fas fa-calendar-alt"></i>
            Start Date
          <% end %>
          <%= form.date_field :start_date, class: 'form-control', required: true %>
          <small class="form-text">When the project will begin</small>
        </div>

        <div class="form-group">
          <%= form.label :end_date, class: 'form-label required' do %>
            <i class="fas fa-calendar-check"></i>
            End Date
          <% end %>
          <%= form.date_field :end_date, class: 'form-control', required: true %>
          <small class="form-text">Expected project completion date</small>
        </div>

        <div class="form-group">
          <%= form.label :customer_budget, class: 'form-label required' do %>
            <i class="fas fa-dollar-sign"></i>
            Customer Budget
          <% end %>
          <%= form.number_field :customer_budget, class: 'form-control', 
              placeholder: 'Enter budget amount', 
              step: 0.01, min: 0, required: true %>
          <small class="form-text">Total budget allocated for this project</small>
        </div>
      </div>
    </div>

    <!-- Assignment Information Section -->
    <div class="col-md-6 mb-4">
      <div class="form-section">
        <h3 class="form-section-title">
          <i class="fas fa-users-cog"></i>
          Assignment & Management
        </h3>
        
        <div class="form-group">
          <%= form.label :company_id, class: 'form-label required' do %>
            <i class="fas fa-building"></i>
            Company
          <% end %>
          <%= form.collection_select :company_id, Company.all, :id, :name, 
              { prompt: 'Select a company' }, 
              { class: 'form-control', required: true } %>
          <small class="form-text">Company responsible for this project</small>
        </div>

        <div class="form-group">
          <%= form.label :user_id, class: 'form-label required' do %>
            <i class="fas fa-user-tie"></i>
            Project Manager
          <% end %>
          <%= form.collection_select :user_id, User.all, :id, :email, 
              { prompt: 'Select a project manager' }, 
              { class: 'form-control', required: true } %>
          <small class="form-text">User responsible for managing this project</small>
        </div>

        <div class="info-panel">
          <h4 class="info-title">
            <i class="fas fa-info-circle"></i>
            Project Guidelines
          </h4>
          <ul class="info-list">
            <li><strong>Name:</strong> Choose a clear, descriptive project name</li>
            <li><strong>Location:</strong> Include city, state, or specific address</li>
            <li><strong>Status:</strong> Start with 'Planning' for new projects</li>
            <li><strong>Manager:</strong> Assign to the lead project coordinator</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="form-actions">
    <div class="d-flex gap-3">
      <%= form.submit class: 'btn btn-primary btn-lg' do %>
        <i class="fas fa-save"></i>
        Save Project
      <% end %>
      <%= link_to projects_path, class: 'btn btn-secondary btn-lg' do %>
        <i class="fas fa-times"></i>
        Cancel
      <% end %>
    </div>
  </div>
<% end %>