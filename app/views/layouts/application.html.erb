<!DOCTYPE html>
<html lang="en">

<head>
    <title><%= content_for(:title) || "Riye - Construction Management System" %></title>
    <meta name="description" content="Professional construction management system for projects, workers, and teams">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Google Fonts %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%# Font Awesome for icons %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <%# Stylesheets %>
    <%= stylesheet_link_tag :application, "data-turbo-track": "reload" %>
    <%= javascript_include_tag :application, "data-turbo-track": "reload" %>
</head>

<body class="<%= controller_name %>-<%= action_name %>">
    <!-- Sidebar Navigation -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <%= link_to root_path, class: "sidebar-brand" do %>
            <i class="fas fa-hard-hat"></i>
            <span class="brand-text">Riye</span>
            <% end %>
        </div>

        <nav class="sidebar-menu">
            <%= link_to root_path, class: "sidebar-link #{'active' if current_page?(root_path)}" do %>
            <i class="fas fa-home"></i>
            <span>Dashboard</span>
            <% end %>

            <%= link_to workers_path, class: "sidebar-link #{'active' if controller_name == 'workers'}" do %>
            <i class="fas fa-users"></i>
            <span>Workers</span>
            <% end %>

            <%= link_to teams_path, class: "sidebar-link #{'active' if controller_name == 'teams'}" do %>
            <i class="fas fa-users-cog"></i>
            <span>Teams</span>
            <% end %>

            <%= link_to team_heads_path, class: "sidebar-link #{'active' if controller_name == 'team_heads'}" do %>
            <i class="fas fa-user-tie"></i>
            <span>Team Heads</span>
            <% end %>

            <%= link_to users_path, class: "sidebar-link #{'active' if controller_name == 'users'}" do %>
            <i class="fas fa-users-cog"></i>
            <span>Users</span>
            <% end %>

            <%= link_to bank_details_path, class: "sidebar-link #{'active' if controller_name == 'bank_details'}" do %>
            <i class="fas fa-university"></i>
            <span>Bank Details</span>
            <% end %>

            <%= link_to projects_path, class: "sidebar-link #{'active' if controller_name == 'projects'}" do %>
            <i class="fas fa-project-diagram"></i>
            <span>Projects</span>
            <% end %>

            <%= link_to companies_path, class: "sidebar-link #{'active' if controller_name == 'companies'}" do %>
            <i class="fas fa-building"></i>
            <span>Companies</span>
            <% end %>

            <%= link_to attendances_path, class: "sidebar-link #{'active' if controller_name == 'attendances'}" do %>
            <i class="fas fa-clock"></i>
            <span>Attendance</span>
            <% end %>

            <%= link_to stocks_path, class: "sidebar-link #{'active' if controller_name == 'stocks'}" do %>
            <i class="fas fa-boxes"></i>
            <span>Stock</span>
            <% end %>

            <%= link_to daily_updates_path, class: "sidebar-link #{'active' if controller_name == 'daily_updates'}" do %>
            <i class="fas fa-clipboard-list"></i>
            <span>Updates</span>
            <% end %>

            <%= link_to api_accesses_path, class: "sidebar-link #{'active' if controller_name == 'api_accesses'}" do %>
            <i class="fas fa-key"></i>
            <span>API Keys</span>
            <% end %>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-toggle-btn" id="sidebarToggle">
                <i class="fas fa-angle-left"></i>
            </div>
        </div>
    </aside>

    <!-- Top Header -->
    <header class="top-header">
        <div class="header-left">
            <div class="mobile-menu-btn" id="mobileMenuBtn">
                <i class="fas fa-bars"></i>
            </div>

            <!-- Page Title -->
            <div class="page-title-section">
                <% page_data = page_title_with_icon(controller_name) %>
                <div class="current-page">
                    <i class="<%= page_data[:icon] %> text-primary"></i>
                    <span class="page-name"><%= page_data[:title] %></span>
                </div>
            </div>
        </div>

        <div class="header-center">
            <div class="search-bar">
                <div class="search-input-wrapper">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" class="search-input" placeholder="Search anything..." id="globalSearch">
                    <div class="search-filters">
                        <button class="filter-btn" id="filterBtn">
                            <i class="fas fa-filter"></i>
                            Filters
                        </button>
                    </div>
                </div>
                <div class="search-dropdown" id="searchDropdown" style="display: none;">
                    <div class="search-results">
                        <div class="search-category">
                            <h6>Quick Actions</h6>
                            <a href="#" class="search-item">
                                <i class="fas fa-user-plus"></i>
                                Add New Worker
                            </a>
                            <a href="#" class="search-item">
                                <i class="fas fa-project-diagram"></i>
                                Create Project
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="header-right">
            <div class="header-actions">
                <button class="header-btn notification-btn">
                    <i class="fas fa-bell"></i>
                    <span class="notification-badge">3</span>
                </button>

                <% if user_signed_in? %>
                <button class="header-btn switch-user-btn" id="switchUserBtn" title="Switch User">
                    <i class="fas fa-user-friends"></i>
                    <span class="btn-text">Switch</span>
                </button>
                <% end %>

                <% if user_signed_in? %>
                <div class="user-dropdown">
                    <button class="user-dropdown-btn" id="userDropdownBtn">
                        <div class="user-avatar">
                            <% case current_user.role %>
                            <% when 'admin' %>
                            <i class="fas fa-user-shield text-danger"></i>
                            <% when 'manager' %>
                            <i class="fas fa-user-tie text-info"></i>
                            <% when 'owner' %>
                            <i class="fas fa-crown text-warning"></i>
                            <% else %>
                            <i class="fas fa-user-circle text-secondary"></i>
                            <% end %>
                        </div>
                        <div class="user-info">
                            <div class="user-name"><%= current_user.email.split('@').first.titleize %></div>
                            <div class="user-role">
                                <% case current_user.role %>
                                <% when 'admin' %>
                                <span class="role-badge admin">Admin</span>
                                <% when 'manager' %>
                                <span class="role-badge manager">Manager</span>
                                <% when 'owner' %>
                                <span class="role-badge owner">Owner</span>
                                <% else %>
                                <span class="role-badge employee">Employee</span>
                                <% end %>
                            </div>
                        </div>
                        <i class="fas fa-chevron-down dropdown-arrow"></i>
                    </button>

                    <div class="user-dropdown-menu" id="userDropdownMenu" style="display: none;">
                        <%= link_to user_path(current_user), class: "dropdown-item" do %>
                        <i class="fas fa-user"></i>
                        View Profile
                        <% end %>
                        <%= link_to edit_user_path(current_user), class: "dropdown-item" do %>
                        <i class="fas fa-cog"></i>
                        Settings
                        <% end %>
                        <div class="dropdown-divider"></div>
                        <%= link_to destroy_user_session_path, method: :delete, class: "dropdown-item text-danger", data: { turbo_method: :delete } do %>
                        <i class="fas fa-sign-out-alt"></i>
                        Logout
                        <% end %>
                    </div>
                </div>
                <% else %>
                <div class="auth-buttons">
                    <%= link_to "Login", new_user_session_path, class: "btn btn-outline-primary btn-sm" %>
                    <% if respond_to?(:new_user_registration_path) && Devise.mappings[:user].registerable? %>
                    <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-primary btn-sm" %>
                    <% end %>
                </div>
                <% end %>
            </div>
        </div>
    </header>

    <!-- Floating Create Button -->
    <% create_button_data = get_create_button_data(controller_name) %>
    <% if create_button_data && (!defined?(@hide_create_button) || !@hide_create_button) %>
    <div class="floating-create-btn" id="floatingCreateBtn">
        <%= link_to create_button_data[:path], class: "create-btn", title: create_button_data[:title] do %>
        <i class="fas fa-plus"></i>
        <span class="btn-text"><%= create_button_data[:text] %></span>
        <% end %>
    </div>
    <% end %>

    <!-- Main Content Area -->
    <main class="main-content">
        <div class="content-container">
            <%# Flash Messages %>
            <% flash.each do |type, message| %>
            <div class="flash flash-<%= type %>" data-flash>
                <div class="flash-content">
                    <i class="fas fa-<%= type == 'notice' ? 'check-circle' : 'exclamation-triangle' %>"></i>
                    <span><%= message %></span>
                    <button class="flash-close" data-flash-close>
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
            <% end %>

            <%# Page Content %>
            <%= yield %>
        </div>
    </main>

    <!-- Footer -->
    <footer class="main-footer">
        <div class="footer-content">
            <div class="footer-section">
                <div class="footer-brand">
                    <h4><i class="fas fa-hard-hat"></i> Riye Construction</h4>
                    <p>Professional construction management system</p>
                </div>
            </div>

            <div class="footer-section">
                <h5>Quick Links</h5>
                <ul class="footer-links">
                    <li><%= link_to "Dashboard", root_path %></li>
                    <li><%= link_to "Workers", workers_path %></li>
                    <li><%= link_to "Projects", projects_path %></li>
                    <li><%= link_to "Teams", teams_path %></li>
                </ul>
            </div>

            <div class="footer-section">
                <h5>Management</h5>
                <ul class="footer-links">
                    <li><%= link_to "Attendance", attendances_path %></li>
                    <li><%= link_to "Stock Management", stocks_path %></li>
                    <li><%= link_to "Companies", companies_path %></li>
                    <li><%= link_to "Daily Updates", daily_updates_path %></li>
                </ul>
            </div>

            <div class="footer-section">
                <h5>Contact</h5>
                <div class="contact-info">
                    <p><i class="fas fa-envelope"></i> info@riyeconstruction.com</p>
                    <p><i class="fas fa-phone"></i> +1 (555) 123-4567</p>
                    <p><i class="fas fa-map-marker-alt"></i> Construction Excellence</p>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="footer-bottom-content">
                <p>&copy; 2025 Riye Construction Management System. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <%# Switch User Modal %>
    <div class="modal-overlay" id="switchUserModal" style="display: none;">
        <div class="modal-content switch-user-modal">
            <div class="modal-header">
                <h3><i class="fas fa-user-friends"></i> Switch User</h3>
                <button class="modal-close" id="switchUserModalClose">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
                <%= form_with url: switch_user_path, method: :post, local: false, id: "switchUserForm", class: "switch-user-form" do |form| %>
                <div class="form-group">
                    <label for="switch_user_email">
                        <i class="fas fa-envelope"></i>
                        Email Address
                    </label>
                    <%= form.email_field :email, class: "form-control", id: "switch_user_email", placeholder: "Enter user email", required: true, autocomplete: "username" %>
                </div>

                <div class="form-group">
                    <label for="switch_user_password">
                        <i class="fas fa-lock"></i>
                        Password
                    </label>
                    <%= form.password_field :password, class: "form-control", id: "switch_user_password", placeholder: "Enter password", required: true, autocomplete: "current-password" %>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" id="cancelSwitchUser">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-exchange-alt"></i>
                        Switch User
                    </button>
                </div>
                <% end %>

                <div class="switch-user-help">
                    <p><i class="fas fa-info-circle"></i> Enter the credentials of the user you want to switch to.</p>
                </div>
            </div>
        </div>
    </div>

    <%# Loading Overlay %>
    <div class="loading-overlay" id="loadingOverlay">
        <div class="loading-spinner">
            <div class="spinner"></div>
            <p>Loading...</p>
        </div>
    </div>

    <%# Sidebar and Header JavaScript %>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Sidebar functionality
            const sidebar = document.getElementById('sidebar');
            const sidebarToggle = document.getElementById('sidebarToggle');
            const mobileMenuBtn = document.getElementById('mobileMenuBtn');

            // Desktop sidebar toggle
            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', function() {
                    sidebar.classList.toggle('collapsed');

                    // Save state to localStorage
                    const isCollapsed = sidebar.classList.contains('collapsed');
                    localStorage.setItem('sidebarCollapsed', isCollapsed);
                });
            }

            // Load saved sidebar state
            const savedSidebarState = localStorage.getItem('sidebarCollapsed');
            if (savedSidebarState === 'true') {
                sidebar.classList.add('collapsed');
            }


            // Mobile menu toggle
            if (mobileMenuBtn) {
                mobileMenuBtn.addEventListener('click', function() {
                    sidebar.classList.toggle('mobile-open');

                    const isOpen = sidebar.classList.contains('mobile-open');
                    const icon = mobileMenuBtn.querySelector('i');
                    if (icon) {
                        icon.className = isOpen ? 'fas fa-times' : 'fas fa-bars';
                    }
                });
            }

            // Close mobile menu when clicking outside
            document.addEventListener('click', function(e) {
                if (window.innerWidth <= 768) {
                    if (!sidebar.contains(e.target) && !mobileMenuBtn.contains(e.target)) {
                        sidebar.classList.remove('mobile-open');
                        const icon = mobileMenuBtn.querySelector('i');
                        if (icon) {
                            icon.className = 'fas fa-bars';
                        }
                    }
                }
            });

            // Close mobile menu when clicking on sidebar links
            const sidebarLinks = sidebar.querySelectorAll('.sidebar-link');
            sidebarLinks.forEach(link => {
                link.addEventListener('click', function() {
                    if (window.innerWidth <= 768) {
                        sidebar.classList.remove('mobile-open');
                        const icon = mobileMenuBtn.querySelector('i');
                        if (icon) {
                            icon.className = 'fas fa-bars';
                        }
                    }
                });
            });

            // User dropdown functionality
            const userDropdownBtn = document.getElementById('userDropdownBtn');
            const userDropdownMenu = document.getElementById('userDropdownMenu');

            if (userDropdownBtn && userDropdownMenu) {
                userDropdownBtn.addEventListener('click', function() {
                    const isOpen = userDropdownMenu.style.display === 'block';
                    userDropdownMenu.style.display = isOpen ? 'none' : 'block';
                    userDropdownBtn.setAttribute('aria-expanded', !isOpen);
                });

                // Close dropdown when clicking outside
                document.addEventListener('click', function(e) {
                    if (!userDropdownBtn.contains(e.target) && !userDropdownMenu.contains(e.target)) {
                        userDropdownMenu.style.display = 'none';
                        userDropdownBtn.setAttribute('aria-expanded', 'false');
                    }
                });
            }

            // Search functionality
            const globalSearch = document.getElementById('globalSearch');
            const searchDropdown = document.getElementById('searchDropdown');

            if (globalSearch && searchDropdown) {
                globalSearch.addEventListener('focus', function() {
                    searchDropdown.style.display = 'block';
                });

                globalSearch.addEventListener('blur', function() {
                    setTimeout(() => {
                        searchDropdown.style.display = 'none';
                    }, 200);
                });

                globalSearch.addEventListener('input', function() {
                    const query = this.value.toLowerCase();
                    // Here you can add search functionality
                    console.log('Searching for:', query);
                });
            }

            // Filter button functionality
            const filterBtn = document.getElementById('filterBtn');
            if (filterBtn) {
                filterBtn.addEventListener('click', function() {
                    // Add filter functionality here
                    console.log('Filter button clicked');
                    alert('Filter functionality will be implemented here');
                });
            }

            // Notification functionality
            const notificationBtn = document.querySelector('.notification-btn');
            if (notificationBtn) {
                notificationBtn.addEventListener('click', function() {
                    // Add notification functionality here
                    console.log('Notification button clicked');
                    alert('Notification panel will be implemented here');
                });
            }

            // Switch User Modal functionality
            const switchUserBtn = document.getElementById('switchUserBtn');
            const switchUserModal = document.getElementById('switchUserModal');
            const switchUserModalClose = document.getElementById('switchUserModalClose');
            const cancelSwitchUser = document.getElementById('cancelSwitchUser');
            const switchUserForm = document.getElementById('switchUserForm');

            // Open switch user modal
            if (switchUserBtn) {
                switchUserBtn.addEventListener('click', function() {
                    switchUserModal.style.display = 'flex';
                    document.body.style.overflow = 'hidden';
                    // Focus on email input
                    setTimeout(() => {
                        document.getElementById('switch_user_email').focus();
                    }, 100);
                });
            }

            // Close modal functions
            function closeSwitchUserModal() {
                switchUserModal.style.display = 'none';
                document.body.style.overflow = 'auto';
                // Reset form
                if (switchUserForm) {
                    switchUserForm.reset();
                }
            }

            // Close modal events
            if (switchUserModalClose) {
                switchUserModalClose.addEventListener('click', closeSwitchUserModal);
            }

            if (cancelSwitchUser) {
                cancelSwitchUser.addEventListener('click', closeSwitchUserModal);
            }

            // Close modal on overlay click
            if (switchUserModal) {
                switchUserModal.addEventListener('click', function(e) {
                    if (e.target === switchUserModal) {
                        closeSwitchUserModal();
                    }
                });
            }

            // Handle form submission
            if (switchUserForm) {
                switchUserForm.addEventListener('submit', function(e) {
                    e.preventDefault();

                    const email = document.getElementById('switch_user_email').value;
                    const password = document.getElementById('switch_user_password').value;

                    if (!email || !password) {
                        alert('Please enter both email and password.');
                        return;
                    }

                    // Show loading
                    const submitBtn = switchUserForm.querySelector('button[type="submit"]');
                    const originalText = submitBtn.innerHTML;
                    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Switching...';
                    submitBtn.disabled = true;

                    // Submit form data
                    fetch(switchUserForm.action, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
                            },
                            body: JSON.stringify({
                                email: email,
                                password: password
                            })
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                // Show success message and reload
                                alert('Successfully switched to ' + data.user_email);
                                window.location.reload();
                            } else {
                                // Show error message
                                alert(data.error || 'Invalid credentials. Please try again.');
                            }
                        })
                        .catch(error => {
                            console.error('Switch user error:', error);
                            alert('An error occurred. Please try again.');
                        })
                        .finally(() => {
                            // Reset button
                            submitBtn.innerHTML = originalText;
                            submitBtn.disabled = false;
                        });
                });
            }

            // Flash message auto-hide
            const flashMessages = document.querySelectorAll('[data-flash]');
            flashMessages.forEach(flash => {
                const closeBtn = flash.querySelector('[data-flash-close]');
                if (closeBtn) {
                    closeBtn.addEventListener('click', function() {
                        flash.style.animation = 'slideOutUp 0.3s ease-in forwards';
                        setTimeout(() => flash.remove(), 300);
                    });
                }

                // Auto-hide after 5 seconds
                setTimeout(() => {
                    if (flash.parentNode) {
                        flash.style.animation = 'slideOutUp 0.3s ease-in forwards';
                        setTimeout(() => flash.remove(), 300);
                    }
                }, 5000);
            });


            // Handle window resize
            window.addEventListener('resize', function() {
                if (window.innerWidth > 768) {
                    sidebar.classList.remove('mobile-open');
                    const mobileIcon = mobileMenuBtn?.querySelector('i');
                    if (mobileIcon) {
                        mobileIcon.className = 'fas fa-bars';
                    }
                }

            });
        });
    </script>
</body>

</html>