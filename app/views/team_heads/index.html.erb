<div class="animate-fade-in">

  <!-- Stats Cards -->
  <div class="stats-grid mb-5">
    <div class="stat-card">
      <div class="stat-icon text-primary">
        <i class="fas fa-user-tie"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @team_heads.count %></h3>
        <p class="stat-label">Total Team Heads</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-success">
        <i class="fas fa-users-cog"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @team_heads.joins(:teams).distinct.count %></h3>
        <p class="stat-label">Active Heads</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-info">
        <i class="fas fa-venus-mars"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @team_heads.distinct.count(:gender) %></h3>
        <p class="stat-label">Gender Types</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-warning">
        <i class="fas fa-calculator"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @team_heads.average(:age)&.round || 0 %></h3>
        <p class="stat-label">Average Age</p>
      </div>
    </div>
  </div>

  <!-- Team Heads Table -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">
        <i class="fas fa-list"></i>
        All Team Heads
      </h3>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover table-striped mb-0">
          <thead class="table-dark">
            <tr>
              <th><i class="fas fa-user-tie"></i> Name</th>
              <th><i class="fas fa-birthday-cake"></i> Age</th>
              <th><i class="fas fa-venus-mars"></i> Gender</th>
              <th><i class="fas fa-phone"></i> Contact</th>
              <th><i class="fas fa-id-card"></i> Aadhaar</th>
              <th><i class="fas fa-users-cog"></i> Teams</th>
              <th class="text-end"><i class="fas fa-cogs"></i> Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if @team_heads.any? %>
              <% @team_heads.each do |team_head| %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <i class="fas fa-user-tie text-primary me-2"></i>
                      <strong><%= team_head.name %></strong>
                    </div>
                  </td>
                  <td>
                    <span class="badge bg-info">
                      <i class="fas fa-birthday-cake"></i>
                      <%= team_head.age %> years
                    </span>
                  </td>
                  <td>
                    <span class="badge <%= team_head.gender&.downcase == 'male' ? 'bg-primary' : 'bg-success' %>">
                      <i class="fas fa-<%= team_head.gender&.downcase == 'male' ? 'mars' : 'venus' %>"></i>
                      <%= team_head.gender %>
                    </span>
                  </td>
                  <td>
                    <i class="fas fa-phone text-success me-1"></i>
                    <%= team_head.contact_number %>
                  </td>
                  <td>
                    <small class="text-muted">
                      <i class="fas fa-id-card me-1"></i>
                      <%= team_head.aadhaar_number %>
                    </small>
                  </td>
                  <td>
                    <% if team_head.teams.any? %>
                      <% team_head.teams.each do |team| %>
                        <span class="badge bg-info me-1">
                          <i class="fas fa-users-cog"></i>
                          <%= team.name %>
                        </span>
                      <% end %>
                    <% else %>
                      <span class="text-muted">
                        <i class="fas fa-users-slash"></i>
                        No teams assigned
                      </span>
                    <% end %>
                  </td>
                  <td class="text-end">
                    <div class="btn-group btn-group-sm">
                      <%= link_to team_head_path(team_head), class: 'btn btn-outline-primary', title: 'View Details' do %>
                        <i class="fas fa-eye"></i>
                      <% end %>
                      <%= link_to edit_team_head_path(team_head), class: 'btn btn-outline-warning', title: 'Edit Team Head' do %>
                        <i class="fas fa-edit"></i>
                      <% end %>
                      <%= link_to team_head_path(team_head), method: :delete,
                          class: 'btn btn-outline-danger', title: 'Delete Team Head',
                          confirm: 'Are you sure you want to delete this team head?' do %>
                        <i class="fas fa-trash"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  <i class="fas fa-user-tie fa-2x mb-2"></i>
                  <br>No team heads found. <br>
                  <%= link_to 'Add your first team head', new_team_head_path, class: 'btn btn-success btn-sm mt-2' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
