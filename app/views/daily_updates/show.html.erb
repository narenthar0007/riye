<h1>Daily Update</h1>
<div class="update-card" style="border:1px solid #ccc; border-radius:8px; margin-bottom:1em; padding:1em; max-width:700px; margin:auto;">
    <div style="font-weight:bold;">Site Engineer: <%= @daily_update.user&.email || 'Unknown' %>
        <span style="float:right; color:#888; font-size:0.9em;"> <%= @daily_update.created_at.strftime('%b %d, %Y %H:%M') %> </span>
    </div>
    <div style="margin:0.5em 0 1em 0; white-space:pre-line;"> <%= @daily_update.note %> </div>
    <div style="margin-top:1em;">
        <% if @daily_update.approved? %>
        <span class="badge bg-success">Approved</span>
        <% else %>
        <%= button_to 'Approve Task', approve_daily_update_path(@daily_update), method: :patch, class: 'btn btn-success btn-sm' %>
        <% end %>
    </div>
</div>
<div class="replies-section" style="max-width:700px; margin:auto;">
    <h3>Replies</h3>
    <% @daily_update.replies.each do |reply| %>
    <div style="margin-left:1em; color:#333; margin-bottom:0.5em; padding:0.5em; background:#f8f9fa; border-radius:6px;">
        <div style="font-weight:bold; margin-bottom:0.25em;">
            <%= reply.user&.email || 'Unknown' %>
            <span style="color:#aaa; font-size:0.8em; font-weight:normal;"> <%= reply.created_at.strftime('%b %d, %Y %H:%M') %> </span>
        </div>
        <% if reply.content.present? %>
        <div style="margin-bottom:0.5em;"><%= reply.content %></div>
        <% end %>
        <% if reply.image.attached? %>
        <div class="reply-image">
            <%= image_tag reply.image, style: 'max-width:200px; height:auto; border-radius:4px; border:1px solid #ced4da;' %>
        </div>
        <% end %>
    </div>
    <% end %>
    <%= form_with url: daily_update_replies_path(@daily_update), method: :post, local: true, class: 'reply-form', multipart: true do |f| %>
    <div class="reply-input-container">
        <%= f.text_area :content, placeholder: 'Write your reply here...', class: 'reply-textarea', rows: 3 %>
        
        <div class="reply-image-upload">
            <label for="reply_image" class="image-upload-label">
                <i class="fas fa-camera"></i>
                <span>Add Photo</span>
            </label>
            <%= f.file_field :image, id: 'reply_image', class: 'image-upload-input', accept: 'image/*' %>
            <div class="image-preview" id="imagePreview" style="display: none;">
                <img id="previewImg" src="" alt="Preview" class="preview-image">
                <button type="button" class="remove-image-btn" onclick="removeImage()">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>
        
        <div class="reply-button-container">
            <%= f.submit 'Reply', class: 'btn btn-primary' %>
        </div>
    </div>
    <% end %>
</div>
<style>
    .badge.bg-success {
        background: #28a745;
        color: #fff;
        padding: 0.3em 0.7em;
        border-radius: 0.5em;
    }
    
    .reply-form {
        margin-top: 1.5em;
        padding: 1em;
        background: #f8f9fa;
        border-radius: 8px;
        border: 1px solid #e9ecef;
    }
    
    .reply-input-container {
        display: flex;
        flex-direction: column;
        gap: 0.75em;
    }
    
    .reply-textarea {
        width: 100%;
        min-height: 80px;
        padding: 0.75em;
        border: 1px solid #ced4da;
        border-radius: 6px;
        font-family: inherit;
        font-size: 14px;
        line-height: 1.5;
        resize: vertical;
        transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }
    
    .reply-textarea:focus {
        outline: none;
        border-color: #007bff;
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
    }
    
    .reply-button-container {
        display: flex;
        justify-content: flex-end;
    }
    
    .reply-button-container .btn {
        padding: 0.5em 1.5em;
        font-weight: 500;
    }
    
    .reply-image-upload {
        margin: 0.5em 0;
    }
    
    .image-upload-label {
        display: inline-flex;
        align-items: center;
        gap: 0.5em;
        padding: 0.5em 1em;
        background: #f8f9fa;
        border: 2px dashed #ced4da;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 14px;
        color: #6c757d;
    }
    
    .image-upload-label:hover {
        background: #e9ecef;
        border-color: #007bff;
        color: #007bff;
    }
    
    .image-upload-input {
        display: none;
    }
    
    .image-preview {
        position: relative;
        margin-top: 0.5em;
        max-width: 200px;
    }
    
    .preview-image {
        width: 100%;
        height: auto;
        border-radius: 6px;
        border: 1px solid #ced4da;
    }
    
    .remove-image-btn {
        position: absolute;
        top: -8px;
        right: -8px;
        background: #dc3545;
        color: white;
        border: none;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 12px;
    }
    
    .remove-image-btn:hover {
        background: #c82333;
    }
    
    @media (min-width: 768px) {
        .reply-input-container {
            flex-direction: row;
            align-items: flex-end;
        }
        
        .reply-textarea {
            flex: 1;
            margin-right: 0.75em;
        }
        
        .reply-button-container {
            flex-shrink: 0;
        }
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const imageInput = document.getElementById('reply_image');
    const imagePreview = document.getElementById('imagePreview');
    const previewImg = document.getElementById('previewImg');
    
    if (imageInput) {
        imageInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImg.src = e.target.result;
                    imagePreview.style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });
    }
});

function removeImage() {
    const imageInput = document.getElementById('reply_image');
    const imagePreview = document.getElementById('imagePreview');
    
    if (imageInput) {
        imageInput.value = '';
    }
    if (imagePreview) {
        imagePreview.style.display = 'none';
    }
}
</script>