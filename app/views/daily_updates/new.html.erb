<h1>New Daily Update</h1>
<div class="messaging-form" style="max-width: 600px; margin: 2em auto; background: #f9f9f9; border-radius: 8px; padding: 2em; box-shadow: 0 2px 8px #eee;">
    <%= form_with(model: @daily_update, local: true) do |form| %>
    <% if @daily_update.errors.any? %>
    <div id="error_explanation">
        <h2><%= pluralize(@daily_update.errors.count, "error") %> prohibited this update from being saved:</h2>
        <ul>
            <% @daily_update.errors.full_messages.each do |message| %>
            <li><%= message %></li>
            <% end %>
        </ul>
    </div>
    <% end %>
    <div class="form-group" style="margin-bottom: 1.5em;">
        <%= form.label :note, 'Update Message', style: 'font-weight: bold;' %><br>
        <%= form.text_area :note, rows: 5, class: 'form-control', style: 'width: 100%; border-radius: 6px; border: 1px solid #ccc; padding: 1em;' %>
    </div>
    <div class="form-group">
        <%= form.submit 'Send Update', class: 'btn btn-success', style: 'width: 100%; font-size: 1.2em;' %>
    </div>
    <% end %>
</div>