<div class="animate-fade-in">

  <!-- Stats Cards -->
  <div class="stats-grid mb-5">
    <div class="stat-card">
      <div class="stat-icon text-primary">
        <i class="fas fa-boxes"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @stocks.count %></h3>
        <p class="stat-label">Total Stock Items</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-success">
        <i class="fas fa-layer-group"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @stocks.sum(:quantity) %></h3>
        <p class="stat-label">Total Quantity</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-info">
        <i class="fas fa-building"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @stocks.joins(:company).distinct.count('companies.id') %></h3>
        <p class="stat-label">Companies</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-warning">
        <i class="fas fa-tags"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @stocks.distinct.count(:unit) %></h3>
        <p class="stat-label">Unit Types</p>
      </div>
    </div>
  </div>

  <!-- Stocks Table -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">
        <i class="fas fa-list"></i>
        All Stock Items
      </h3>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover table-striped mb-0">
          <thead class="table-dark">
            <tr>
              <th><i class="fas fa-boxes"></i> Item Name</th>
              <th><i class="fas fa-sort-numeric-up"></i> Quantity</th>
              <th><i class="fas fa-weight"></i> Unit</th>
              <th><i class="fas fa-building"></i> Company</th>
              <th class="text-end"><i class="fas fa-cogs"></i> Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if @stocks.any? %>
              <% @stocks.each do |stock| %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <i class="fas fa-box text-primary me-2"></i>
                      <strong><%= stock.name %></strong>
                    </div>
                  </td>
                  <td>
                    <span class="badge bg-success">
                      <i class="fas fa-sort-numeric-up"></i>
                      <%= stock.quantity %>
                    </span>
                  </td>
                  <td>
                    <span class="badge bg-info">
                      <i class="fas fa-weight"></i>
                      <%= stock.unit %>
                    </span>
                  </td>
                  <td>
                    <% if stock.company %>
                      <i class="fas fa-building text-info me-1"></i>
                      <%= stock.company.name %>
                    <% else %>
                      <span class="text-muted">
                        <i class="fas fa-building-slash"></i>
                        No company assigned
                      </span>
                    <% end %>
                  </td>
                  <td class="text-end">
                    <div class="btn-group btn-group-sm">
                      <%= link_to stock_path(stock), class: 'btn btn-outline-primary', title: 'View Details' do %>
                        <i class="fas fa-eye"></i>
                      <% end %>
                      <%= link_to edit_stock_path(stock), class: 'btn btn-outline-warning', title: 'Edit Stock' do %>
                        <i class="fas fa-edit"></i>
                      <% end %>
                      <%= link_to stock_path(stock), method: :delete,
                          class: 'btn btn-outline-danger', title: 'Delete Stock',
                          confirm: 'Are you sure you want to delete this stock item?' do %>
                        <i class="fas fa-trash"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="5" class="text-center text-muted py-4">
                  <i class="fas fa-boxes fa-2x mb-2"></i>
                  <br>No stock items found. <br>
                  <%= link_to 'Add your first stock item', new_stock_path, class: 'btn btn-success btn-sm mt-2' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>