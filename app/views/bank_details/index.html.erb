<div class="animate-fade-in">

  <!-- Stats Cards -->
  <div class="stats-grid mb-5">
    <div class="stat-card">
      <div class="stat-icon text-primary">
        <i class="fas fa-university"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @bank_details.count %></h3>
        <p class="stat-label">Total Bank Details</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-success">
        <i class="fas fa-building-columns"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @bank_details.distinct.count(:bank_name) %></h3>
        <p class="stat-label">Different Banks</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-info">
        <i class="fas fa-code-branch"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @bank_details.distinct.count(:branch_name) %></h3>
        <p class="stat-label">Different Branches</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-warning">
        <i class="fas fa-users"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= Worker.joins(:bank_detail).count %></h3>
        <p class="stat-label">Workers with Bank Details</p>
      </div>
    </div>
  </div>

  <!-- Bank Details Table -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">
        <i class="fas fa-list"></i>
        All Bank Details
      </h3>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover table-striped mb-0">
          <thead class="table-dark">
            <tr>
              <th><i class="fas fa-user"></i> Worker</th>
              <th><i class="fas fa-id-badge"></i> Worker ID</th>
              <th><i class="fas fa-user-circle"></i> Beneficiary</th>
              <th><i class="fas fa-university"></i> Bank</th>
              <th><i class="fas fa-code-branch"></i> Branch</th>
              <th><i class="fas fa-credit-card"></i> Account</th>
              <th><i class="fas fa-key"></i> IFSC</th>
              <th class="text-end"><i class="fas fa-cogs"></i> Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if @bank_details.any? %>
              <% @bank_details.each do |bank_detail| %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <i class="fas fa-user text-primary me-2"></i>
                      <%= link_to worker_path(bank_detail.worker), class: 'text-primary text-decoration-none fw-bold' do %>
                        <%= bank_detail.worker.name %>
                      <% end %>
                    </div>
                  </td>
                  <td>
                    <span class="badge bg-info">
                      <i class="fas fa-id-badge"></i>
                      <%= bank_detail.worker.worker_id %>
                    </span>
                  </td>
                  <td>
                    <i class="fas fa-user-circle text-success me-1"></i>
                    <%= bank_detail.name_of_beneficiary %>
                  </td>
                  <td>
                    <div>
                      <i class="fas fa-university text-primary me-1"></i>
                      <strong><%= bank_detail.bank_name %></strong>
                    </div>
                  </td>
                  <td>
                    <i class="fas fa-code-branch text-info me-1"></i>
                    <%= bank_detail.branch_name %>
                  </td>
                  <td>
                    <code class="bg-light p-1 rounded">
                      <i class="fas fa-credit-card me-1"></i>
                      <%= bank_detail.formatted_account_number || bank_detail.account_number %>
                    </code>
                  </td>
                  <td>
                    <code class="bg-light p-1 rounded">
                      <i class="fas fa-key me-1"></i>
                      <%= bank_detail.ifsc_code %>
                    </code>
                  </td>
                  <td class="text-end">
                    <div class="btn-group btn-group-sm">
                      <%= link_to bank_detail_path(bank_detail), class: 'btn btn-outline-primary', title: 'View Details' do %>
                        <i class="fas fa-eye"></i>
                      <% end %>
                      <%= link_to edit_bank_detail_path(bank_detail), class: 'btn btn-outline-warning', title: 'Edit Bank Details' do %>
                        <i class="fas fa-edit"></i>
                      <% end %>
                      <%= link_to bank_detail_path(bank_detail), method: :delete,
                          class: 'btn btn-outline-danger', title: 'Delete Bank Details',
                          confirm: 'Are you sure you want to delete these bank details?' do %>
                        <i class="fas fa-trash"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="8" class="text-center text-muted py-4">
                  <i class="fas fa-university fa-2x mb-2"></i>
                  <br>No bank details found. <br>
                  <small>Workers' bank details will appear here once added.</small><br>
                  <%= link_to 'View Workers', workers_path, class: 'btn btn-success btn-sm mt-2' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
