<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">Bank Details</h3>
        </div>
        <div class="card-body">
          <div class="row">
            <div class="col-md-6">
              <h5>Worker Information</h5>
              <table class="table table-bordered">
                <tr>
                  <th>Worker Name</th>
                  <td><%= @bank_detail.worker.name %></td>
                </tr>
                <tr>
                  <th>Worker ID</th>
                  <td><%= @bank_detail.worker.worker_id %></td>
                </tr>
                <tr>
                  <th>Contact</th>
                  <td><%= @bank_detail.worker.contact %></td>
                </tr>
                <tr>
                  <th>Project</th>
                  <td><%= @bank_detail.worker.project&.name %></td>
                </tr>
              </table>
            </div>
            
            <div class="col-md-6">
              <h5>Banking Information</h5>
              <table class="table table-bordered">
                <tr>
                  <th>Beneficiary Name</th>
                  <td><%= @bank_detail.name_of_beneficiary %></td>
                </tr>
                <tr>
                  <th>Account Number</th>
                  <td>
                    <code><%= @bank_detail.formatted_account_number %></code>
                    <small class="text-muted d-block">Last 4 digits shown for security</small>
                  </td>
                </tr>
                <tr>
                  <th>Bank Name</th>
                  <td><%= @bank_detail.bank_name %></td>
                </tr>
                <tr>
                  <th>IFSC Code</th>
                  <td><code><%= @bank_detail.ifsc_code %></code></td>
                </tr>
                <tr>
                  <th>Branch Name</th>
                  <td><%= @bank_detail.branch_name %></td>
                </tr>
              </table>
            </div>
          </div>
          
          <div class="alert alert-info mt-4">
            <div class="d-flex align-center gap-2">
              <i class="fas fa-shield-alt"></i>
              <div>
                <strong>Security Note:</strong> Full account numbers are masked for security. 
                Only authorized personnel can view complete banking information.
              </div>
            </div>
          </div>
          
          <div class="mt-4">
            <%= link_to 'Edit', edit_bank_detail_path(@bank_detail), class: 'btn btn-warning' %>
            <%= link_to 'Worker Details', worker_path(@bank_detail.worker), class: 'btn btn-info' %>
            <%= link_to 'All Workers', workers_path, class: 'btn btn-secondary' %>
            <%= link_to 'Delete', @bank_detail, method: :delete, 
                confirm: 'Are you sure you want to delete these bank details?', class: 'btn btn-danger' %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
