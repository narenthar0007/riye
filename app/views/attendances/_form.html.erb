<%= form_with(model: attendance, local: true, class: 'modern-form') do |form| %>
  <% if attendance.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <div class="d-flex align-center gap-2 mb-3">
        <i class="fas fa-exclamation-triangle fa-lg"></i>
        <h3 class="mb-0">Please fix the following errors:</h3>
      </div>
      <ul class="mb-0">
        <% attendance.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <!-- Attendance Information Section -->
    <div class="col-md-6 mb-4">
      <div class="form-section">
        <h3 class="form-section-title">
          <i class="fas fa-clock"></i>
          Attendance Details
        </h3>
        
        <div class="form-group">
          <%= form.label :worker_id, class: 'form-label required' do %>
            <i class="fas fa-user"></i>
            Worker
          <% end %>
          <%= form.collection_select :worker_id, Worker.all, :id, 
              lambda { |worker| 
                worker_id_display = worker.worker_id.present? ? " (#{worker.worker_id})" : ""
                project_info = worker.project ? " - #{worker.project.name}" : ""
                "#{worker.name}#{worker_id_display}#{project_info}"
              }, 
              { prompt: 'Select a worker' }, 
              { class: 'form-control', required: true } %>
          <small class="form-text">Choose the worker for attendance tracking</small>
        </div>

        <div class="form-group">
          <%= form.label :punch_in, class: 'form-label' do %>
            <i class="fas fa-sign-in-alt"></i>
            Punch In Time
          <% end %>
          <%= form.datetime_local_field :punch_in, class: 'form-control' %>
          <small class="form-text">When the worker started work</small>
        </div>

        <div class="form-group">
          <%= form.label :punch_out, class: 'form-label' do %>
            <i class="fas fa-sign-out-alt"></i>
            Punch Out Time
          <% end %>
          <%= form.datetime_local_field :punch_out, class: 'form-control' %>
          <small class="form-text">When the worker finished work</small>
        </div>
      </div>
    </div>

    <!-- Location & Status Section -->
    <div class="col-md-6 mb-4">
      <div class="form-section">
        <h3 class="form-section-title">
          <i class="fas fa-map-marker-alt"></i>
          Location & Status
        </h3>
        
        <div class="form-group">
          <%= form.label :punch_in_location, class: 'form-label' do %>
            <i class="fas fa-map-pin"></i>
            Punch In Location
          <% end %>
          <%= form.text_field :punch_in_location, class: 'form-control', 
              placeholder: 'Enter punch in location' %>
          <small class="form-text">Location where worker punched in</small>
        </div>

        <div class="form-group">
          <%= form.label :punch_out_location, class: 'form-label' do %>
            <i class="fas fa-map-pin"></i>
            Punch Out Location
          <% end %>
          <%= form.text_field :punch_out_location, class: 'form-control', 
              placeholder: 'Enter punch out location' %>
          <small class="form-text">Location where worker punched out</small>
        </div>

        <div class="form-group">
          <%= form.label :approved, class: 'form-label' do %>
            <i class="fas fa-check-circle"></i>
            Approval Status
          <% end %>
          <div class="form-check">
            <%= form.check_box :approved, class: 'form-check-input' %>
            <%= form.label :approved, 'Mark as Approved', class: 'form-check-label' %>
          </div>
          <small class="form-text">Check if this attendance record is approved</small>
        </div>

        <div class="info-panel">
          <h4 class="info-title">
            <i class="fas fa-info-circle"></i>
            Attendance Guidelines
          </h4>
          <ul class="info-list">
            <li><strong>Times:</strong> Punch out time should be after punch in</li>
            <li><strong>Location:</strong> Optional but helps with tracking</li>
            <li><strong>Approval:</strong> Required for payroll processing</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="form-actions">
    <div class="d-flex gap-3">
      <%= form.submit class: 'btn btn-primary btn-lg' do %>
        <i class="fas fa-save"></i>
        Save Attendance
      <% end %>
      <%= link_to attendances_path, class: 'btn btn-secondary btn-lg' do %>
        <i class="fas fa-times"></i>
        Cancel
      <% end %>
    </div>
  </div>
<% end %>