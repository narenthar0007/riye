<h1>Edit Attendance</h1>
<%= form_with(model: @attendance, local: true) do |form| %>
<% if @attendance.errors.any? %>
<div id="error_explanation">
    <h2><%= pluralize(@attendance.errors.count, "error") %> prohibited this attendance from being saved:</h2>
    <ul>
        <% @attendance.errors.full_messages.each do |message| %>
        <li><%= message %></li>
        <% end %>
    </ul>
</div>
<% end %>
<div class="field">
    <%= form.label :punch_in %>
    <%= form.datetime_select :punch_in %>
</div>
<div class="field">
    <%= form.label :punch_in_location %>
    <%= form.text_field :punch_in_location %>
</div>
<div class="field">
    <%= form.label :punch_out %>
    <%= form.datetime_select :punch_out %>
</div>
<div class="field">
    <%= form.label :punch_out_location %>
    <%= form.text_field :punch_out_location %>
</div>
<div class="actions">
    <%= form.submit 'Update Attendance', class: 'btn btn-success' %>
</div>
<% end %>
<%= link_to 'Back', attendances_path, class: 'btn btn-secondary' %>