<% content_for :title, "Login - Riye Construction" %>

<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-logo">
        <i class="fas fa-hard-hat"></i>
        <h1>Riye</h1>
      </div>
      <h2>Welcome Back</h2>
      <p>Sign in to your construction management account</p>
    </div>

    <div class="auth-form">
      <%= form_with model: resource, as: resource_name, url: session_path(resource_name), class: "modern-form", local: true do |form| %>
        <div class="form-group">
          <%= form.label :email, class: "form-label" do %>
            <i class="fas fa-envelope"></i>
            Email Address
          <% end %>
          <%= form.email_field :email, autofocus: true, autocomplete: "email", 
              class: "form-control", placeholder: "your.email@company.com" %>
        </div>

        <div class="form-group">
          <%= form.label :password, class: "form-label" do %>
            <i class="fas fa-lock"></i>
            Password
          <% end %>
          <%= form.password_field :password, autocomplete: "current-password", 
              class: "form-control", placeholder: "Enter your password" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="form-group">
            <label class="checkbox-container">
              <%= form.check_box :remember_me %>
              <span class="checkmark"></span>
              <span class="checkbox-text">Remember me for 30 days</span>
            </label>
          </div>
        <% end %>

        <div class="form-actions">
          <%= form.submit "Sign In", class: "btn btn-primary btn-block" %>
        </div>
      <% end %>
    </div>

    <div class="auth-footer">
      <div class="auth-links">
        <%= link_to "Forgot Password?", new_password_path(resource_name), class: "auth-link" %>
        <% if devise_mapping.registerable? %>
          <%= link_to "Create Account", new_registration_path(resource_name), class: "auth-link primary" %>
        <% end %>
      </div>
      
      <div class="auth-info">
        <p><small>Construction Management System</small></p>
        <p><small>&copy; <%= Date.current.year %> Riye. All rights reserved.</small></p>
      </div>
    </div>
  </div>
</div>
