<div class="animate-fade-in">

  <!-- Stats Cards -->
  <div class="stats-grid mb-5">
    <div class="stat-card">
      <div class="stat-icon text-primary">
        <i class="fas fa-building"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @companies.count %></h3>
        <p class="stat-label">Total Companies</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-success">
        <i class="fas fa-project-diagram"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @companies.joins(:projects).distinct.count %></h3>
        <p class="stat-label">Companies with Projects</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-info">
        <i class="fas fa-boxes"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @companies.joins(:stocks).distinct.count %></h3>
        <p class="stat-label">Companies with Stock</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-warning">
        <i class="fas fa-calendar-plus"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @companies.order(:created_at).first&.created_at&.year || Date.current.year %></h3>
        <p class="stat-label">Established Since</p>
      </div>
    </div>
  </div>

  <!-- Companies Table -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">
        <i class="fas fa-list"></i>
        All Companies
      </h3>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover table-striped mb-0">
          <thead class="table-dark">
            <tr>
              <th><i class="fas fa-building"></i> Company Name</th>
              <th><i class="fas fa-project-diagram"></i> Projects</th>
              <th><i class="fas fa-boxes"></i> Stock Items</th>
              <th><i class="fas fa-calendar"></i> Created</th>
              <th class="text-end"><i class="fas fa-cogs"></i> Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if @companies.any? %>
              <% @companies.each do |company| %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <i class="fas fa-building text-primary me-2"></i>
                      <strong><%= company.name %></strong>
                    </div>
                  </td>
                  <td>
                    <% projects_count = company.projects.count %>
                    <% if projects_count > 0 %>
                      <span class="badge bg-success">
                        <i class="fas fa-project-diagram"></i>
                        <%= projects_count %> Projects
                      </span>
                    <% else %>
                      <span class="badge bg-secondary">
                        <i class="fas fa-project-diagram"></i>
                        No Projects
                      </span>
                    <% end %>
                  </td>
                  <td>
                    <% stocks_count = company.stocks.count %>
                    <% if stocks_count > 0 %>
                      <span class="badge bg-info">
                        <i class="fas fa-boxes"></i>
                        <%= stocks_count %> Items
                      </span>
                    <% else %>
                      <span class="badge bg-secondary">
                        <i class="fas fa-boxes"></i>
                        No Stock
                      </span>
                    <% end %>
                  </td>
                  <td>
                    <%= company.created_at.strftime("%B %d, %Y") %>
                  </td>
                  <td class="text-end">
                    <div class="btn-group btn-group-sm">
                      <%= link_to company_path(company), class: 'btn btn-outline-primary', title: 'View Details' do %>
                        <i class="fas fa-eye"></i>
                      <% end %>
                      <%= link_to edit_company_path(company), class: 'btn btn-outline-warning', title: 'Edit Company' do %>
                        <i class="fas fa-edit"></i>
                      <% end %>
                      <%= link_to company_path(company), method: :delete,
                          class: 'btn btn-outline-danger', title: 'Delete Company',
                          confirm: 'Are you sure you want to delete this company?' do %>
                        <i class="fas fa-trash"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="5" class="text-center text-muted py-4">
                  <i class="fas fa-building fa-2x mb-2"></i>
                  <br>No companies found. <br>
                  <%= link_to 'Add your first company', new_company_path, class: 'btn btn-success btn-sm mt-2' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>