<%= form_with(model: company, local: true, class: 'modern-form') do |form| %>
  <% if company.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <div class="d-flex align-center gap-2 mb-3">
        <i class="fas fa-exclamation-triangle fa-lg"></i>
        <h3 class="mb-0">Please fix the following errors:</h3>
      </div>
      <ul class="mb-0">
        <% company.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <!-- Company Information Section -->
    <div class="col-md-8 mb-4">
      <div class="form-section">
        <h3 class="form-section-title">
          <i class="fas fa-building"></i>
          Company Information
        </h3>
        
        <div class="form-group">
          <%= form.label :name, class: 'form-label required' do %>
            <i class="fas fa-building"></i>
            Company Name
          <% end %>
          <%= form.text_field :name, class: 'form-control', 
              placeholder: 'Enter company name',
              required: true %>
          <small class="form-text">Official name of the construction company</small>
        </div>
      </div>
    </div>

    <!-- Guidelines Section -->
    <div class="col-md-4 mb-4">
      <div class="info-panel">
        <h4 class="info-title">
          <i class="fas fa-info-circle"></i>
          Company Guidelines
        </h4>
        <ul class="info-list">
          <li><strong>Name:</strong> Enter the official company name</li>
          <li><strong>Format:</strong> Include "Ltd", "Inc", etc. if applicable</li>
          <li><strong>Uniqueness:</strong> Each company name should be unique</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Form Actions -->
  <div class="form-actions">
    <div class="d-flex gap-3">
      <%= form.submit class: 'btn btn-primary btn-lg' do %>
        <i class="fas fa-save"></i>
        Save Company
      <% end %>
      <%= link_to companies_path, class: 'btn btn-secondary btn-lg' do %>
        <i class="fas fa-times"></i>
        Cancel
      <% end %>
    </div>
  </div>
<% end %>