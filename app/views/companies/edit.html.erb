<!DOCTYPE html>
<html>

<head>
    <title>Edit Company</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all' %>
    <%= javascript_pack_tag 'application' %>
</head>

<body>
    <h1>Edit Company</h1>
    <p>You are editing an existing company.</p>
    <%= link_to 'Back to Home', root_path, class: 'btn btn-secondary', style: 'margin-bottom: 1em; margin-right: 1em;' %>
    <%= link_to 'Back to Companies', companies_path, class: 'btn btn-primary', style: 'margin-bottom: 1em;' %>
    <%= render 'form', company: @company %>
</body>

</html>