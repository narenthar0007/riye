<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">
            <i class="fas fa-user"></i>
            Worker Details
          </h3>
          <div class="card-tools">
            <%= link_to 'Edit Worker', edit_worker_path(@worker), class: 'btn btn-warning btn-sm' %>
            <%= link_to 'All Workers', workers_path, class: 'btn btn-secondary btn-sm' %>
          </div>
        </div>
        <div class="card-body">
          <div class="row">
            <!-- Worker Information -->
            <div class="col-md-6">
              <h5>
                <i class="fas fa-user-circle"></i>
                Personal Information
              </h5>
              <table class="table table-bordered">
                <tr>
                  <th>Worker ID</th>
                  <td><code><%= @worker.worker_id %></code></td>
                </tr>
                <tr>
                  <th>Full Name</th>
                  <td><%= @worker.name %></td>
                </tr>
                <tr>
                  <th>Contact Number</th>
                  <td><%= @worker.contact %></td>
                </tr>
                <tr>
                  <th>Project</th>
                  <td>
                    <% if @worker.project %>
                      <strong><%= @worker.project.name %></strong>
                      <% if @worker.project.location %>
                        <br><small class="text-muted">📍 <%= @worker.project.location %></small>
                      <% end %>
                    <% else %>
                      <span class="text-muted">No project assigned</span>
                    <% end %>
                  </td>
                </tr>
                <tr>
                  <th>Team</th>
                  <td>
                    <% if @worker.team %>
                      <%= @worker.team.name %>
                      <span class="badge badge-info ml-2"><%= @worker.team.nature_of_skill&.titleize %></span>
                    <% else %>
                      <span class="text-muted">No team assigned</span>
                    <% end %>
                  </td>
                </tr>
                <tr>
                  <th>Head Worker</th>
                  <td>
                    <% if @worker.head_worker %>
                      <strong><%= @worker.head_worker.name %></strong>
                      <br><small class="text-muted">ID: <%= @worker.head_worker.worker_id %></small>
                    <% else %>
                      <span class="badge badge-success">HEAD WORKER</span>
                    <% end %>
                  </td>
                </tr>
              </table>

              <% if @worker.subordinates.any? %>
                <h6 class="mt-4">
                  <i class="fas fa-users"></i>
                  Subordinates (<%= @worker.subordinates.count %>)
                </h6>
                <div class="list-group">
                  <% @worker.subordinates.limit(5).each do |subordinate| %>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                      <div>
                        <strong><%= subordinate.name %></strong>
                        <br><small class="text-muted"><%= subordinate.worker_id %></small>
                      </div>
                      <%= link_to 'View', worker_path(subordinate), class: 'btn btn-sm btn-outline-primary' %>
                    </div>
                  <% end %>
                  <% if @worker.subordinates.count > 5 %>
                    <div class="list-group-item text-center">
                      <small class="text-muted">... and <%= @worker.subordinates.count - 5 %> more</small>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>

            <!-- Bank Details -->
            <div class="col-md-6">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5>
                  <i class="fas fa-university"></i>
                  Bank Details
                </h5>
                <% if @worker.bank_detail %>
                  <%= link_to 'Edit Bank Details', edit_bank_detail_path(@worker.bank_detail), class: 'btn btn-warning btn-sm' %>
                <% else %>
                  <%= link_to 'Add Bank Details', new_worker_bank_detail_path(@worker), class: 'btn btn-success btn-sm' %>
                <% end %>
              </div>

              <% if @worker.bank_detail %>
                <table class="table table-bordered">
                  <tr>
                    <th>Beneficiary Name</th>
                    <td><%= @worker.bank_detail.name_of_beneficiary %></td>
                  </tr>
                  <tr>
                    <th>Account Number</th>
                    <td>
                      <code><%= @worker.bank_detail.formatted_account_number %></code>
                      <small class="text-muted d-block">Masked for security</small>
                    </td>
                  </tr>
                  <tr>
                    <th>Bank Name</th>
                    <td><%= @worker.bank_detail.bank_name %></td>
                  </tr>
                  <tr>
                    <th>Branch Name</th>
                    <td><%= @worker.bank_detail.branch_name %></td>
                  </tr>
                  <tr>
                    <th>IFSC Code</th>
                    <td><code><%= @worker.bank_detail.ifsc_code %></code></td>
                  </tr>
                </table>

                <div class="alert alert-success">
                  <i class="fas fa-check-circle"></i>
                  <strong>Bank details are complete</strong> - Ready for payroll processing
                </div>
              <% else %>
                <div class="alert alert-warning">
                  <div class="d-flex align-items-center gap-2">
                    <i class="fas fa-exclamation-triangle"></i>
                    <div>
                      <strong>No bank details found</strong>
                      <p class="mb-0">Add bank details to enable salary payments</p>
                    </div>
                  </div>
                </div>

                <div class="text-center py-4">
                  <i class="fas fa-university fa-3x text-muted mb-3"></i>
                  <p class="text-muted">Bank details are required for salary processing</p>
                  <%= link_to 'Add Bank Details Now', new_worker_bank_detail_path(@worker), 
                      class: 'btn btn-primary' %>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Timestamps -->
          <div class="row mt-4 pt-4 border-top">
            <div class="col-md-6">
              <small class="text-muted">
                <i class="fas fa-calendar-plus"></i>
                <strong>Created:</strong> <%= @worker.created_at.strftime('%B %d, %Y at %I:%M %p') %>
              </small>
            </div>
            <div class="col-md-6">
              <% if @worker.updated_at != @worker.created_at %>
                <small class="text-muted">
                  <i class="fas fa-calendar-edit"></i>
                  <strong>Last Updated:</strong> <%= @worker.updated_at.strftime('%B %d, %Y at %I:%M %p') %>
                </small>
              <% end %>
            </div>
          </div>

          <!-- Actions -->
          <div class="mt-4 pt-3 border-top">
            <div class="d-flex gap-2">
              <%= link_to 'Edit Worker', edit_worker_path(@worker), class: 'btn btn-warning' %>
              <% if @worker.bank_detail %>
                <%= link_to 'View Full Bank Details', @worker.bank_detail, class: 'btn btn-info' %>
              <% else %>
                <%= link_to 'Add Bank Details', new_worker_bank_detail_path(@worker), class: 'btn btn-success' %>
              <% end %>
              <%= link_to 'All Workers', workers_path, class: 'btn btn-secondary' %>
              <%= link_to 'Delete Worker', worker_path(@worker), method: :delete, 
                  confirm: 'Are you sure? This will also delete associated bank details.', 
                  class: 'btn btn-danger' %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>