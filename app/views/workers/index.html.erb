<div class="animate-fade-in">

  <!-- Stats Cards -->
  <div class="stats-grid mb-5">
    <div class="stat-card">
      <div class="stat-icon text-primary">
        <i class="fas fa-users"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @workers.count %></h3>
        <p class="stat-label">Total Workers</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-info">
        <i class="fas fa-user-tie"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @workers.where.not(team_id: nil).count %></h3>
        <p class="stat-label">Assigned to Teams</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-success">
        <i class="fas fa-project-diagram"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= Project.count %></h3>
        <p class="stat-label">Active Projects</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-warning">
        <i class="fas fa-layer-group"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= Team.count %></h3>
        <p class="stat-label">Teams Available</p>
      </div>
    </div>
  </div>

  <!-- Search and Filter -->
  <div class="card mb-4">
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-3">
          <label for="searchWorkers" class="form-label">Search Workers</label>
          <div class="input-group">
            <span class="input-group-prepend">
              <i class="fas fa-search"></i>
            </span>
            <input type="text" id="searchWorkers" class="form-control" placeholder="Search by name, contact, or project..." data-search="tbody tr">
          </div>
        </div>
        
        <div class="col-md-3 mb-3">
          <label for="filterTeam" class="form-label">Filter by Team</label>
          <select id="filterTeam" class="form-control">
            <option value="">All Teams</option>
            <% Team.all.each do |team| %>
              <option value="<%= team.id %>"><%= team.name %> (<%= team.nature_of_skill %>)</option>
            <% end %>
          </select>
        </div>
        
        <div class="col-md-3 mb-3">
          <label for="filterProject" class="form-label">Filter by Project</label>
          <select id="filterProject" class="form-control">
            <option value="">All Projects</option>
            <% Project.all.each do |project| %>
              <option value="<%= project.id %>"><%= project.name %></option>
            <% end %>
          </select>
        </div>
      </div>
    </div>
  </div>

  <!-- Workers Table -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">
        <i class="fas fa-list"></i>
        All Workers
      </h3>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover table-striped mb-0">
          <thead class="table-dark">
            <tr>
              <th data-sort="name">
                <i class="fas fa-user"></i>
                Name
              </th>
              <th data-sort="contact">
                <i class="fas fa-phone"></i>
                Contact
              </th>
              <th data-sort="project">
                <i class="fas fa-project-diagram"></i>
                Project
              </th>
              <th data-sort="head_worker">
                <i class="fas fa-user-tie"></i>
                Head Worker
              </th>
              <th data-sort="team">
                <i class="fas fa-users-cog"></i>
                Team & Skill
              </th>
              <th data-sort="bank">
                <i class="fas fa-university"></i>
                Bank Details
              </th>
              <th class="text-end">
                <i class="fas fa-cogs"></i>
                Actions
              </th>
            </tr>
          </thead>
      <tbody>
        <% @workers.each do |worker| %>
          <tr data-worker-id="<%= worker.id %>" data-team-id="<%= worker.team_id %>" data-project-id="<%= worker.project_id %>">
            <td>
              <div class="d-flex align-center gap-2">
                <div class="worker-avatar">
                  <i class="fas fa-user-circle fa-2x text-primary"></i>
                </div>
                <div>
                  <strong><%= worker.name %></strong>
                  <br>
                  <small class="text-gray-600">ID: <%= worker.worker_id %></small>
                </div>
              </div>
            </td>
            
            <td>
              <div class="d-flex align-center gap-2">
                <i class="fas fa-phone text-success"></i>
                <span><%= worker.contact %></span>
              </div>
            </td>
            
            <td>
              <% if worker.project %>
                <div class="d-flex align-center gap-2">
                  <i class="fas fa-building text-info"></i>
                  <div>
                    <strong><%= worker.project.name %></strong>
                    <% if worker.project.location %>
                      <br>
                      <small class="text-gray-600">
                        <i class="fas fa-map-marker-alt"></i>
                        <%= worker.project.location %>
                      </small>
                    <% end %>
                  </div>
                </div>
              <% else %>
                <span class="text-gray-400">
                  <i class="fas fa-minus-circle"></i>
                  No project assigned
                </span>
              <% end %>
            </td>
            
            <td>
              <% if worker.head_worker %>
                <div class="d-flex align-center gap-2">
                  <i class="fas fa-user-tie text-warning"></i>
                  <div>
                    <strong><%= worker.head_worker.name %></strong>
                    <br>
                    <small class="text-gray-600">ID: <%= worker.head_worker.worker_id %></small>
                  </div>
                </div>
              <% else %>
                <span class="text-success">
                  <i class="fas fa-crown"></i>
                  HEAD WORKER
                </span>
              <% end %>
            </td>
            
            <td>
              <% if worker.team %>
                <div class="team-info">
                  <div class="d-flex align-center gap-2 mb-1">
                    <i class="fas fa-users text-primary"></i>
                    <strong><%= worker.team.name %></strong>
                  </div>
                  <% if worker.team.nature_of_skill.present? %>
                    <span class="badge badge-<%= 
                      case worker.team.nature_of_skill
                      when 'electrical' then 'warning'
                      when 'plumbing' then 'info'
                      when 'carpentry' then 'success'
                      when 'masonry' then 'danger'
                      else 'primary'
                      end %>">
                      <i class="fas fa-<%= 
                        case worker.team.nature_of_skill
                        when 'electrical' then 'bolt'
                        when 'plumbing' then 'wrench'
                        when 'carpentry' then 'hammer'
                        when 'masonry' then 'layer-group'
                        else 'users'
                        end %>"></i>
                      <%= case worker.team.nature_of_skill
                        when 'masonry' then 'Masonry'
                        when 'electrical' then 'Electrical'
                        when 'plumbing' then 'Plumbing'
                        when 'carpentry' then 'Carpentry'
                        when 'local_team' then 'Local Team'
                        else worker.team.nature_of_skill.humanize
                        end %>
                    </span>
                  <% end %>
                </div>
              <% else %>
                <span class="text-gray-400">
                  <i class="fas fa-minus-circle"></i>
                  No team assigned
                </span>
              <% end %>
            </td>
            
            <td>
              <% if worker.bank_detail %>
                <div class="d-flex align-center gap-2">
                  <i class="fas fa-university text-success"></i>
                  <div>
                    <strong><%= worker.bank_detail.bank_name %></strong>
                    <br>
                    <small class="text-gray-600">
                      <code><%= worker.bank_detail.formatted_account_number %></code>
                    </small>
                  </div>
                </div>
              <% else %>
                <div class="text-center">
                  <span class="text-warning">
                    <i class="fas fa-exclamation-triangle"></i>
                    <small>Missing</small>
                  </span>
                  <br>
                  <%= link_to 'Add', new_worker_bank_detail_path(worker), 
                      class: 'btn btn-success btn-xs mt-1', title: 'Add Bank Details' %>
                </div>
              <% end %>
            </td>
            
            <td class="text-end">
              <div class="btn-group btn-group-sm">
                <%= link_to worker_path(worker), class: 'btn btn-outline-primary', title: 'View Details' do %>
                  <i class="fas fa-eye"></i>
                <% end %>
                
                <%= link_to edit_worker_path(worker), class: 'btn btn-outline-warning', title: 'Edit Worker' do %>
                  <i class="fas fa-edit"></i>
                <% end %>
                
                <%= link_to worker_path(worker), method: :delete, 
                    data: { confirm: 'Are you sure you want to delete this worker?' }, 
                    class: 'btn btn-outline-danger', title: 'Delete Worker' do %>
                  <i class="fas fa-trash"></i>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
            <% if @workers.empty? %>
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  <i class="fas fa-users fa-2x mb-2"></i>
                  <br>No workers found. <br>
                  <%= link_to 'Add your first worker', new_worker_path, class: 'btn btn-success btn-sm mt-2' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<style>
  .worker-avatar {
    flex-shrink: 0;
  }
  
  .team-info {
    min-width: 120px;
  }
  
  .action-buttons {
    min-width: 120px;
  }
  
  .empty-state {
    background: var(--gray-50);
    border-radius: var(--radius-lg);
    margin: 2rem;
  }
  
  .input-group {
    position: relative;
    display: flex;
    align-items: center;
  }
  
  .input-group-prepend {
    position: absolute;
    left: 12px;
    z-index: 10;
    color: var(--gray-400);
  }
  
  .input-group .form-control {
    padding-left: 40px;
  }
  
  .form-label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
    color: var(--gray-700);
    font-size: 0.875rem;
  }
  
  @media (max-width: 768px) {
    .action-buttons {
      flex-direction: column;
      gap: 0.25rem;
    }
    
    .action-buttons .btn {
      width: 100%;
    }
  }
</style>

<script>
  // Enhanced search and filter functionality
  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchWorkers');
    const teamFilter = document.getElementById('filterTeam');
    const projectFilter = document.getElementById('filterProject');
    const tableRows = document.querySelectorAll('tbody tr');
    
    function filterRows() {
      const searchTerm = searchInput.value.toLowerCase();
      const selectedTeam = teamFilter.value;
      const selectedProject = projectFilter.value;
      
      tableRows.forEach(row => {
        const text = row.textContent.toLowerCase();
        const teamId = row.getAttribute('data-team-id');
        const projectId = row.getAttribute('data-project-id');
        
        const matchesSearch = !searchTerm || text.includes(searchTerm);
        const matchesTeam = !selectedTeam || teamId === selectedTeam;
        const matchesProject = !selectedProject || projectId === selectedProject;
        
        if (matchesSearch && matchesTeam && matchesProject) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
      
      // Show/hide empty state
      const visibleRows = Array.from(tableRows).filter(row => row.style.display !== 'none');
      const emptyState = document.querySelector('.empty-state');
      
      if (visibleRows.length === 0 && emptyState) {
        emptyState.style.display = 'block';
      } else if (emptyState) {
        emptyState.style.display = 'none';
      }
    }
    
    searchInput.addEventListener('input', filterRows);
    teamFilter.addEventListener('change', filterRows);
    projectFilter.addEventListener('change', filterRows);
  });
</script>