<div class="animate-fade-in">

  <!-- Stats Cards -->
  <div class="stats-grid mb-5">
    <div class="stat-card">
      <div class="stat-icon text-primary">
        <i class="fas fa-users-cog"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @teams.count %></h3>
        <p class="stat-label">Total Teams</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-success">
        <i class="fas fa-user-tie"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @teams.joins(:team_head).count %></h3>
        <p class="stat-label">Teams with Heads</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-info">
        <i class="fas fa-users"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= @teams.joins(:workers).distinct.count %></h3>
        <p class="stat-label">Teams with Workers</p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon text-warning">
        <i class="fas fa-layer-group"></i>
      </div>
      <div class="stat-content">
        <h3 class="stat-number"><%= Team.pluck(:nature_of_skill).uniq.count %></h3>
        <p class="stat-label">Skill Categories</p>
      </div>
    </div>
  </div>

  <!-- Teams Table -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">
        <i class="fas fa-list"></i>
        All Teams
      </h3>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-hover table-striped mb-0">
          <thead class="table-dark">
            <tr>
              <th><i class="fas fa-users-cog"></i> Team Name</th>
              <th><i class="fas fa-tools"></i> Skill Type</th>
              <th><i class="fas fa-user-tie"></i> Team Head</th>
              <th><i class="fas fa-users"></i> Workers</th>
              <th class="text-end"><i class="fas fa-cogs"></i> Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if @teams.any? %>
              <% @teams.each do |team| %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <i class="fas fa-users-cog text-primary me-2"></i>
                      <strong><%= team.name %></strong>
                    </div>
                  </td>
                  <td>
                    <span class="badge bg-info">
                      <i class="fas fa-tools"></i>
                      <%= team.nature_of_skill&.titleize || 'General' %>
                    </span>
                  </td>
                  <td>
                    <% if team.team_head %>
                      <div>
                        <i class="fas fa-user-tie text-success me-1"></i>
                        <%= link_to team.team_head.name, team_head_path(team.team_head), 
                            class: 'text-primary text-decoration-none' %>
                        <br>
                        <small class="text-muted">
                          <i class="fas fa-phone"></i>
                          <%= team.team_head.contact_number %>
                        </small>
                      </div>
                    <% else %>
                      <span class="text-muted">
                        <i class="fas fa-user-slash"></i>
                        No head assigned
                      </span>
                    <% end %>
                  </td>
                  <td>
                    <% workers_count = team.workers.count %>
                    <% if workers_count > 0 %>
                      <span class="badge bg-success">
                        <i class="fas fa-users"></i>
                        <%= workers_count %> Workers
                      </span>
                    <% else %>
                      <span class="badge bg-secondary">
                        <i class="fas fa-user-slash"></i>
                        No Workers
                      </span>
                    <% end %>
                  </td>
                  <td class="text-end">
                    <div class="btn-group btn-group-sm">
                      <%= link_to team_path(team), class: 'btn btn-outline-primary', title: 'View Details' do %>
                        <i class="fas fa-eye"></i>
                      <% end %>
                      <%= link_to edit_team_path(team), class: 'btn btn-outline-warning', title: 'Edit Team' do %>
                        <i class="fas fa-edit"></i>
                      <% end %>
                      <%= link_to team_path(team), method: :delete, 
                          class: 'btn btn-outline-danger', title: 'Delete Team',
                          confirm: 'Are you sure you want to delete this team?' do %>
                        <i class="fas fa-trash"></i>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="5" class="text-center text-muted py-4">
                  <i class="fas fa-users-cog fa-2x mb-2"></i>
                  <br>No teams found. <br>
                  <%= link_to 'Create your first team', new_team_path, class: 'btn btn-success btn-sm mt-2' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
